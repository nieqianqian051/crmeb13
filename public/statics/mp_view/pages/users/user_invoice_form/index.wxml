<view class="invoice-form data-v-ee25d588" style="{{(colorStyle)}}"><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e" class="data-v-ee25d588"><view class="panel data-v-ee25d588"><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">发票类型</view><view class="button-group data-v-ee25d588"><block wx:for="{{invoiceTypeList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="value"><view data-event-opts="{{[['tap',[['changeType',['$0'],[[['invoiceTypeList','value',item.value]]]]]]]}}" class="{{['button','data-v-ee25d588',(type==item.value)?'active':'']}}" bindtap="__e">{{item.name}}</view></block></view></view><block wx:if="{{type==1}}"><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">抬头类型</view><view class="button-group data-v-ee25d588"><block wx:for="{{headerTypeList}}" wx:for-item="item" wx:for-index="__i1__" wx:key="value"><view data-event-opts="{{[['tap',[['changeHeaderType',['$0'],[[['headerTypeList','value',item.value,'value']]]]]]]}}" class="{{['button','data-v-ee25d588',(header_type==item.value)?'active':'']}}" bindtap="__e">{{item.name+''}}</view></block></view></view></block><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">发票抬头</view><input name="name" placeholder="请输入发票抬头" value="{{name}}" class="data-v-ee25d588"/></view><view hidden="{{!(header_type==2)}}" class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">单位税号</view><input name="duty_number" placeholder="请输入单位税号" value="{{duty_number}}" class="data-v-ee25d588"/></view><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">{{(header_type==2?'企业':'联系')+"电话"}}</view><input name="drawer_phone" placeholder="{{'请输入'+(header_type==2?'企业':'联系')+'电话'}}" value="{{drawer_phone}}" class="data-v-ee25d588"/></view><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">电子邮箱</view><input name="email" placeholder="请输入电子邮箱" value="{{email}}" class="data-v-ee25d588"/></view><block wx:if="{{type==2}}"><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">开户银行</view><input name="bank" placeholder="请输入开户银行" value="{{bank}}" class="data-v-ee25d588"/></view><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">银行账号</view><input name="card_number" placeholder="请输入银行账号" value="{{card_number}}" class="data-v-ee25d588"/></view><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">企业地址</view><input name="address" placeholder="请输入企业地址" value="{{address}}" class="data-v-ee25d588"/></view><view class="acea-row row-middle data-v-ee25d588"><view class="label data-v-ee25d588">企业电话</view><input name="tell" placeholder="请输入企业电话" value="{{tell}}" class="data-v-ee25d588"/></view></block></view><view class="default acea-row row-between-wrapper data-v-ee25d588"><view class="data-v-ee25d588">设置为默认抬头</view><view data-event-opts="{{[['tap',[['changeDefault',['$event']]]]]}}" class="{{['switch','data-v-ee25d588',(is_default)?'checked':'']}}" bindtap="__e"></view></view><view class="button-section data-v-ee25d588"><button class="button data-v-ee25d588" form-type="submit">保存</button></view></form><home vue-id="6c7d9b49-1" class="data-v-ee25d588" bind:__l="__l"></home></view>